    document.addEventListener('click',function(e){
      var b=e.target&&e.target.closest&&e.target.closest('.btn-pill.btn-gradient');
      if(b)ruTrack('cta_click',{zone:(b.closest('section')||{}).className||'sticky'});
      var t=e.target&&e.target.closest&&e.target.closest('.testimonial-card');
      if(t)ruTrack('testimonial_open',{i:t.dataset.index});
      var ps=e.target&&e.target.closest&&e.target.closest('.proof-strip');
      if(ps)ruTrack('proofstrip_click',{},true);
    },true);
    /* arrivee sur le booking */
    if('IntersectionObserver'in window){
      var bk=document.getElementById('booking-1');
      if(bk)new IntersectionObserver(function(es,o){if(es[0].isIntersecting){ruTrack('booking_view',{},true);o.disconnect();}},{threshold:.3}).observe(bk);
    }
  }catch(e){}
})();
</script>

</body>
</html>
