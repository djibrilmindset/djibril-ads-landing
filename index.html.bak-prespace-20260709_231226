        grid1.querySelectorAll('.testimonial-hidden').forEach(function (c) { c.classList.remove('testimonial-hidden'); setThumb(c); });
        expandBtn.style.display = 'none';
      };
      grid1.parentNode.insertBefore(expandBtn, grid1.nextSibling);
    }

    // Charge Wistia E-v1.js si pas déjà
