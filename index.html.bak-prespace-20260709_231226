      </div>
    `).join('');

    // LAZY THUMBS (deterministe, robuste) : sans background-image inline, le preload-scanner
    // ne prefetch plus les 75 cartes cachees -> ~2 Mo economises au 1er rendu.
    // On charge la vignette des 8 cartes visibles tout de suite, le reste seulement au clic "voir plus".
    function setThumb(c) {
      if (c.dataset.thumb) {
        c.style.backgroundImage = "url('" + c.dataset.thumb + "')";
        c.removeAttribute('data-thumb');
      }
    }
    grid1.querySelectorAll('.testimonial-card:not(.testimonial-hidden)').forEach(setThumb);

    // Inject expand CTA button after grid (couleur pop tres differente du reste)
    if (TEMOIGNAGES_WISTIA.length > TESTIMONIAL_INITIAL_COUNT) {
      const expandBtn = document.createElement('button');
      expandBtn.className = 'testimonials-expand-btn';
      expandBtn.innerHTML = `VOIR LES ${TEMOIGNAGES_WISTIA.length - TESTIMONIAL_INITIAL_COUNT}+ TÉMOIGNAGES ↓`;
